# =============================================================================
# DATABASE — PostgreSQL connection string (used by api-server and db setup)
# =============================================================================

# Full PostgreSQL connection URL including credentials, host, port, and database name.
# Example: postgresql://myuser:mypassword@localhost:5432/memory
DATABASE_URL=postgresql://POSTGRES_USER:POSTGRES_PASSWORD@postgres:5432/POSTGRES_DB

# Credentials used by the postgres Docker service (must match DATABASE_URL above)
POSTGRES_USER=memory
POSTGRES_PASSWORD=changeme
POSTGRES_DB=memory

# =============================================================================
# API AUTHENTICATION — keys that clients must send as Bearer tokens
# =============================================================================

# Single API key for the default tenant (simple single-user setup).
# The client sends:  Authorization: Bearer <MEMORY_API_KEY>
MEMORY_API_KEY=change-me-to-a-long-random-secret

# (Optional) Multi-tenant setup: JSON object mapping API keys to tenant slugs.
# If set, entries here take precedence; MEMORY_API_KEY is still added as "default"
# unless already listed here.
# Example: MEMORY_API_KEYS={"key-alpha":"alice","key-beta":"bob"}
# MEMORY_API_KEYS=

# =============================================================================
# EXTERNAL AI SERVICES
# =============================================================================

# Voyage AI — used to generate embeddings for semantic search.
# Get your key at: https://dash.voyageai.com/
VOYAGE_API_KEY=your-voyage-api-key-here

# Google Gemini — used for entity extraction and note enrichment.
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Node environment — must be "production" for the server to enable pgvector
# objects (embedding column + HNSW index) and skip interactive dev tooling.
NODE_ENV=production

# Internal port the api-server process listens on (not exposed publicly).
# nginx forwards /api traffic to this port inside the Docker network.
PORT=3001

# =============================================================================
# INSPECTOR UI BUILD ARGS (used at Docker build time, not runtime)
# =============================================================================

# Base URL path where the inspector UI is mounted.
# When served at the root via nginx, keep this as "/".
BASE_PATH=/

# API key to embed in the inspector UI bundle at build time.
# This is the same value as MEMORY_API_KEY (or any valid key from MEMORY_API_KEYS).
# It is baked into the static JS bundle — do not use a high-privilege key
# if you expect the inspector to be publicly accessible.
VITE_MEMORY_API_KEY=change-me-to-a-long-random-secret
