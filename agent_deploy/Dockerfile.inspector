# =============================================================================
# Stage 1: Build
# Installs all dependencies and compiles the Vite/React app into static files.
# BASE_PATH and VITE_MEMORY_API_KEY are baked into the bundle at build time.
# =============================================================================
FROM node:22-alpine AS builder

RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

# Build arguments — must be passed via docker-compose build args or --build-arg
ARG BASE_PATH=/
ARG VITE_MEMORY_API_KEY=
# PORT is required by vite.config.ts even during a production build
ARG BUILD_PORT=3000

# Copy workspace manifest files first (maximises layer cache hits)
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./

# Copy all package.json files so pnpm can resolve the workspace graph
COPY artifacts/inspector/package.json ./artifacts/inspector/
COPY lib/api-client-react/package.json ./lib/api-client-react/
COPY lib/api-spec/package.json ./lib/api-spec/
COPY lib/api-zod/package.json ./lib/api-zod/

# Install all workspace dependencies
RUN pnpm install --frozen-lockfile

# Copy source for packages used by inspector
COPY lib/ ./lib/
COPY artifacts/inspector/ ./artifacts/inspector/

# Build the Vite app (outputs to artifacts/inspector/dist/public/)
# PORT must be set to satisfy vite.config.ts validation (value unused for static build)
RUN PORT=${BUILD_PORT} BASE_PATH=${BASE_PATH} MEMORY_API_KEY=${VITE_MEMORY_API_KEY} \
    NODE_ENV=production \
    pnpm --filter @workspace/inspector run build

# =============================================================================
# Stage 2: Serve static files with nginx
# =============================================================================
FROM nginx:alpine AS runtime

# Remove default nginx static assets
RUN rm -rf /usr/share/nginx/html/*

# Copy the built static files from builder
COPY --from=builder /app/artifacts/inspector/dist/public /usr/share/nginx/html

# Custom nginx config for SPA: route all paths to index.html
COPY agent_deploy/nginx/spa.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
